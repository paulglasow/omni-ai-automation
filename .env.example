# ── Automation Tokens ──────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_ABCDEFGHIJKLMNOPQRSTUVWXYZabcdef123456
VERCEL_TOKEN=vercel_AbCdEfGhIjKlMnOpQrStUvWxYz1234567890abcdefgh
SUPABASE_TOKEN=sbp_abcdefghijklmnopqrstuvwxyz1234567890abcd

# ── AI Keys ────────────────────────────────────────────────────────────────────
# These let OmniAI talk to each AI on your behalf.
#
# REQUIRED — core OmniAI features (coding, analysis, writing) need all three:
#   OPENAI_API_KEY      → GPT-4o: agentic workflows, orchestration, general tasks
#   ANTHROPIC_API_KEY   → Claude 3.5: Python GIS scripting, grant drafts, long docs
#   GEMINI_API_KEY      → Gemini 1.5 Pro: site imagery/PDF/map analysis, data/math
#
# OPTIONAL but recommended — enables real-time research in Assist mode:
#   PERPLEXITY_API_KEY  → sonar-pro: zoning updates, funding news, live web search

# Required: OpenAI (GPT-4o) — agentic workflows, orchestration, general reasoning
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz

# Required: Anthropic (Claude 3.5) — GIS scripting, long docs, grant proposals
# Get your key at: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz

# Required: Google Gemini 1.5 Pro — site imagery, PDF/map analysis, data tasks
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSyABCDEFGHIJKLMNOPQRSTUVWXYZ1234567

# Optional (recommended): Perplexity sonar-pro — real-time zoning/funding research
# Without this key, Assist mode routes research queries to GPT-4o instead.
# Get your key at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-abcdefghijklmnopqrstuvwxyz1234567890abcdefghijklmno

