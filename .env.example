# =============================================================================
# OmniAI v4 — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real secrets.
# =============================================================================

# -------------------------------------------------------------------
# Supabase (required for workspaces, usage logging, and auth)
# -------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...       # public, safe to expose in frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9... # PRIVATE — server-side only, never commit

# -------------------------------------------------------------------
# AI Provider API Keys (add at least one)
# -------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIzaSy...
PERPLEXITY_API_KEY=pplx-...

# -------------------------------------------------------------------
# Cost Reporting
# Set to "false" to disable cost estimates in API responses and UI
# -------------------------------------------------------------------
ENABLE_COST_ESTIMATES=true

# -------------------------------------------------------------------
# Workspace Invites
# Random secret used to sign invite tokens (min 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -------------------------------------------------------------------
WORKSPACE_INVITE_SECRET=

# -------------------------------------------------------------------
# Device Authentication (iOS / macOS)
# Random secret for signing device JWTs (min 32 characters, required)
# Must be kept separate from WORKSPACE_INVITE_SECRET to limit blast radius
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -------------------------------------------------------------------
DEVICE_JWT_SECRET=

# -------------------------------------------------------------------
# Vercel Deployment (set in Vercel dashboard, not here)
# -------------------------------------------------------------------
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
