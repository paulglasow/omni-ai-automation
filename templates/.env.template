# OmniAI v4 — Environment Variables Template
# ============================================================
# INSTRUCTIONS:
# 1. Copy this file: cp templates/.env.template .env
# 2. Fill in each value below
# 3. Never commit .env to git (it's already in .gitignore)
# ============================================================

# ── AI Model API Keys ─────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Get from: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=

# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# Get from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# ── GitHub ────────────────────────────────────────────────────
# Get from: https://github.com/settings/tokens
# Required scopes: repo, read:user, user:email
GITHUB_TOKEN=

# ── Financial Integrations (optional) ────────────────────────
# Get from Empower developer settings
EMPOWER_CLIENT_ID=
EMPOWER_CLIENT_SECRET=

# Get from Monarch Money: Settings → Developer Settings → API Tokens
MONARCH_TOKEN=

# ── Hosting & Database ────────────────────────────────────────
# Get from: https://vercel.com/account/tokens
VERCEL_TOKEN=

# Get from: https://supabase.com → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App Settings ──────────────────────────────────────────────
NODE_ENV=production
APP_NAME=omni-ai-v4

# Default AI routing mode: auto | single | parallel
AI_ROUTING_MODE=auto

# Maximum tokens per AI response (controls cost)
MAX_TOKENS_PER_RESPONSE=2000

# Enable financial data integration (true/false)
FINANCIAL_INTEGRATION_ENABLED=false

# Enable GitHub Copilot integration (true/false)
GITHUB_INTEGRATION_ENABLED=false
