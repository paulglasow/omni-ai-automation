# ==============================================================================
# OmniAI v4 — Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it is listed in .gitignore.
#
# Run: cp .env.template .env
# Then edit .env with your real keys.
# ==============================================================================

# ------------------------------------------------------------------------------
# AUTOMATION TOKENS (required for npm run setup)
# ------------------------------------------------------------------------------

# GitHub Personal Access Token
# Generate at: https://github.com/settings/tokens?type=beta
# Required scopes: repo, workflow
GITHUB_TOKEN=

# Vercel API Token
# Generate at: https://vercel.com/account/tokens
VERCEL_TOKEN=

# Supabase Management API Token
# Generate at: https://supabase.com/dashboard/account/tokens
SUPABASE_TOKEN=

# ------------------------------------------------------------------------------
# AI API KEYS (add after running setup)
# ------------------------------------------------------------------------------

# OpenAI API Key — requires billing ($5-10 credit)
# Generate at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini API Key — FREE
# Generate at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Perplexity API Key — requires billing ($5 credit)
# Generate at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# GitHub Copilot Token — requires $10/month subscription
# Generate at: https://github.com/settings/tokens?type=beta
GITHUB_COPILOT_TOKEN=

# ------------------------------------------------------------------------------
# SUPABASE PROJECT (auto-filled by npm run setup)
# ------------------------------------------------------------------------------

# Your Supabase project URL (e.g. https://abcdefgh.supabase.co)
SUPABASE_URL=

# Your Supabase anonymous/public key (safe to use in browser)
SUPABASE_ANON_KEY=

# Your Supabase service role key (keep secret — server-side only)
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------------------------
# VERCEL DEPLOYMENT (auto-filled by npm run setup)
# ------------------------------------------------------------------------------

# Vercel team/org ID (if using a team)
VERCEL_ORG_ID=

# Vercel project ID (auto-generated)
VERCEL_PROJECT_ID=

# ------------------------------------------------------------------------------
# GITHUB REPOSITORY (auto-filled by npm run setup)
# ------------------------------------------------------------------------------

# Your GitHub username
GITHUB_USERNAME=

# Repository name for the OmniAI app
GITHUB_REPO_NAME=omni-ai