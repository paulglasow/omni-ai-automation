# OmniAI v4 — Git Ignore
# These files are excluded from version control for security and cleanliness.

# ── Secrets — NEVER commit these ─────────────────────────────────────────────
.env
.env.local
.env.development
.env.production

# Generated deployment URL (contains your live URL — exclude for privacy)
.deploy-url

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.npm/
.yarn/

# ── Build outputs ─────────────────────────────────────────────────────────────
.next/
out/
dist/
build/
.vercel/

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# ── Editor files ─────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
*.code-workspace
.idea/
*.suo
*.user

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Runtime ───────────────────────────────────────────────────────────────────
*.pid
*.seed
*.pid.lock

# ── Coverage ──────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Temp files ────────────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
